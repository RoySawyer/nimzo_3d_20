#: main_20.cpp:3
msgid "Dock window"
msgstr "Παράθυρο σύνδεσης"

#: main_20.cpp:5
msgid "Check to dock the window with the game moves list box"
msgstr "Επιλέξτε για να αγκυρώσετε το παράθυρο με το πλαίσιο λίστας κινήσεων παιχνιδιού"

#: main_20.cpp:7
msgid "Dock window  :  Check to dock the media player window"
msgstr "Παράθυρο σύνδεσης: Επιλέξτε για να συνδέσετε το παράθυρο του προγράμματος αναπαραγωγής πολυμέσων"

#: main_20.cpp:9
msgid "to the game moves list box."
msgstr "στο πλαίσιο λίστας κινήσεων παιχνιδιού."

#: main_20.cpp:12
msgid "Left margin size"
msgstr "Μέγεθος αριστερού περιθωρίου"

#: main_20.cpp:14
msgid "Enter the left margin size in pixels"
msgstr "Εισαγάγετε το μέγεθος του αριστερού περιθωρίου σε pixel"

#: main_20.cpp:16
msgid "Button space size"
msgstr "Μέγεθος χώρου κουμπιού"

#: main_20.cpp:18
msgid "Enter the button interval space size in pixels"
msgstr "Εισαγάγετε το μέγεθος του διαστήματος κουμπιών σε pixel"

#: main_20.cpp:20
msgid "Button space size  -  Enter the size in pixels for the gap between"
msgstr "Μέγεθος χώρου κουμπιού - Εισαγάγετε το μέγεθος σε pixel για το κενό μεταξύ"

#: main_20.cpp:21
msgid "the move info controls and the buttons in the eval profile panel (0 - 120)"
msgstr "τα χειριστήρια πληροφοριών μετακίνησης και τα κουμπιά στον πίνακα προφίλ αξιολόγησης (0 - 120)"

#: main_20.cpp:23
msgid "Left margin size  :  Enter the size in pixels for the left margin of the graph. (60 - 100)"
msgstr "Μέγεθος αριστερού περιθωρίου: Εισαγάγετε το μέγεθος σε pixel για το αριστερό περιθώριο του γραφήματος. (60 - 100)"

#: main_20.cpp:26
msgid "Nimzo_3d_ml (version 4.3) multi-lingual,"
msgstr "Nimzo_3d_ml (έκδοση 4.3) πολύγλωσσο,"

#: main_20.cpp:28
msgid "An adjourn game feature to save and restore games"
msgstr "Μια λειτουργία αναβολής παιχνιδιού για την αποθήκευση και την επαναφορά παιχνιδιών"

#: main_20.cpp:30
msgid "with their clock times (version 4.2)"
msgstr "με τις ώρες του ρολογιού τους (έκδοση 4.2)"

#: main_20.cpp:32
msgid "An option to dock the media player window (version 4.3)"
msgstr "Μια επιλογή για σύνδεση του παραθύρου του προγράμματος αναπαραγωγής πολυμέσων (έκδοση 4.3)"

#: main_20.cpp:34
msgid "Features added to Nimzo_3d - version 4.3"
msgstr "Χαρακτηριστικά που προστέθηκαν στο Nimzo_3d - έκδοση 4.3"
