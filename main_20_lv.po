#: main_20.cpp:3
msgid "Dock window"
msgstr "Doka logs"

#: main_20.cpp:5
msgid "Check to dock the window with the game moves list box"
msgstr "Atzīmējiet, lai piestiprinātu logu ar spēles gājienu sarakstu"

#: main_20.cpp:7
msgid "Dock window  :  Check to dock the media player window"
msgstr "Dokot logu: atzīmējiet, lai dokotu multivides atskaņotāja logu."

#: main_20.cpp:9
msgid "to the game moves list box."
msgstr "spēles gājienu saraksta lodziņā."

#: main_20.cpp:12
msgid "Left margin size"
msgstr "Kreisās malas izmērs"

#: main_20.cpp:14
msgid "Enter the left margin size in pixels"
msgstr "Ievadiet kreisās malas izmēru pikseļos"

#: main_20.cpp:16
msgid "Button space size"
msgstr "Pogas vietas izmērs"

#: main_20.cpp:18
msgid "Enter the button interval space size in pixels"
msgstr "Ievadiet pogas intervāla atstarpes izmēru pikseļos"

#: main_20.cpp:20
msgid "Button space size  -  Enter the size in pixels for the gap between"
msgstr "Pogas atstarpes izmērs — ievadiet atstarpes izmēru pikseļos starp"

#: main_20.cpp:21
msgid "the move info controls and the buttons in the eval profile panel (0 - 120)"
msgstr "pārvietošanas informācijas vadīklas un pogas novērtēšanas profila panelī (0–120)"

#: main_20.cpp:23
msgid "Left margin size  :  Enter the size in pixels for the left margin of the graph. (60 - 100)"
msgstr "Kreisās malas izmērs: ievadiet diagrammas kreisās malas izmēru pikseļos. (60–100)"

#: main_20.cpp:26
msgid "Nimzo_3d_ml (version 4.3) multi-lingual,"
msgstr "Nimzo_3d_ml (4.3. versija) daudzvalodu,"

#: main_20.cpp:28
msgid "An adjourn game feature to save and restore games"
msgstr "Spēles atlikšanas funkcija spēļu saglabāšanai un atjaunošanai"

#: main_20.cpp:30
msgid "with their clock times (version 4.2)"
msgstr "ar pulksteņa laikiem (4.2. versija)"

#: main_20.cpp:32
msgid "An option to dock the media player window (version 4.3)"
msgstr "Iespēja piestiprināt multivides atskaņotāja logu (4.3. versija)"

#: main_20.cpp:34
msgid "Features added to Nimzo_3d - version 4.3"
msgstr "Nimzo_3d — 4.3 versijai pievienotās funkcijas"
