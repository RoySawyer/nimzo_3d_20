#: main_20.cpp:3
msgid "Dock window"
msgstr "Dockvenster"

#: main_20.cpp:5
msgid "Check to dock the window with the game moves list box"
msgstr "Vink het vakje aan om het venster met de lijst met spelzetten vast te zetten."

#: main_20.cpp:7
msgid "Dock window  :  Check to dock the media player window"
msgstr "Dockvenster: Vink dit vakje aan om het venster van de mediaspeler te docken."

#: main_20.cpp:9
msgid "to the game moves list box."
msgstr "naar het lijstvak met spelzetten."

#: main_20.cpp:12
msgid "Left margin size"
msgstr "Linker margegrootte"

#: main_20.cpp:14
msgid "Enter the left margin size in pixels"
msgstr "Voer de linkermarge in pixels in."

#: main_20.cpp:16
msgid "Button space size"
msgstr "Grootte van de ruimte voor de knop"

#: main_20.cpp:18
msgid "Enter the button interval space size in pixels"
msgstr "Voer de gewenste afstand tussen de knoppen in pixels in."

#: main_20.cpp:20
msgid "Button space size  -  Enter the size in pixels for the gap between"
msgstr "Grootte van de ruimte tussen de knoppen - Voer de gewenste grootte in pixels in voor de ruimte tussen de knoppen."

#: main_20.cpp:21
msgid "the move info controls and the buttons in the eval profile panel (0 - 120)"
msgstr "de bewegingsinfo-bedieningselementen en de knoppen in het evaluatieprofielpaneel (0 - 120)"

#: main_20.cpp:23
msgid "Left margin size  :  Enter the size in pixels for the left margin of the graph. (60 - 100)"
msgstr "Grootte linkermarge: Voer de gewenste grootte in pixels in voor de linkermarge van de grafiek. (60 - 100)"

#: main_20.cpp:26
msgid "Nimzo_3d_ml (version 4.3) multi-lingual,"
msgstr "Nimzo_3d_ml (versie 4.3) meertalig,"

#: main_20.cpp:28
msgid "An adjourn game feature to save and restore games"
msgstr "Een functie om spellen op te slaan en later weer te hervatten."

#: main_20.cpp:30
msgid "with their clock times (version 4.2)"
msgstr "met hun kloktijden (versie 4.2)"

#: main_20.cpp:32
msgid "An option to dock the media player window (version 4.3)"
msgstr "Een optie om het venster van de mediaspeler vast te zetten (versie 4.3)"

#: main_20.cpp:34
msgid "Features added to Nimzo_3d - version 4.3"
msgstr "Nieuwe functies toegevoegd aan Nimzo_3d - versie 4.3"
