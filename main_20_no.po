#: main_20.cpp:3
msgid "Dock window"
msgstr "Dokkvindu"

#: main_20.cpp:5
msgid "Check to dock the window with the game moves list box"
msgstr "Kryss av for å forankre vinduet med listeboksen for spillbevegelser"

#: main_20.cpp:7
msgid "Dock window  :  Check to dock the media player window"
msgstr "Dokke vindu: Kryss av for å dokke mediespillervinduet"

#: main_20.cpp:9
msgid "to the game moves list box."
msgstr "til listeboksen for spillbevegelser."

#: main_20.cpp:12
msgid "Left margin size"
msgstr "Størrelse på venstre marg"

#: main_20.cpp:14
msgid "Enter the left margin size in pixels"
msgstr "Angi størrelsen på venstre marg i piksler"

#: main_20.cpp:16
msgid "Button space size"
msgstr "Størrelse på knappeplass"

#: main_20.cpp:18
msgid "Enter the button interval space size in pixels"
msgstr "Angi størrelsen på knappintervallet i piksler"

#: main_20.cpp:20
msgid "Button space size  -  Enter the size in pixels for the gap between"
msgstr "Størrelse på knappeavstand – Angi størrelsen i piksler for avstanden mellom"

#: main_20.cpp:21
msgid "the move info controls and the buttons in the eval profile panel (0 - 120)"
msgstr "kontrollene for bevegelsesinfo og knappene i evalueringsprofilpanelet (0–120)"

#: main_20.cpp:23
msgid "Left margin size  :  Enter the size in pixels for the left margin of the graph. (60 - 100)"
msgstr "Venstre margstørrelse: Angi størrelsen i piksler for venstre marg av grafen. (60–100)"

#: main_20.cpp:26
msgid "Nimzo_3d_ml (version 4.3) multi-lingual,"
msgstr "Nimzo_3d_ml (versjon 4.3) flerspråklig,"

#: main_20.cpp:28
msgid "An adjourn game feature to save and restore games"
msgstr "En funksjon for å avbryte spillet for å lagre og gjenopprette spill"

#: main_20.cpp:30
msgid "with their clock times (version 4.2)"
msgstr "med klokketidene deres (versjon 4.2)"

#: main_20.cpp:32
msgid "An option to dock the media player window (version 4.3)"
msgstr "Et alternativ for å forankre mediespillervinduet (versjon 4.3)"

#: main_20.cpp:34
msgid "Features added to Nimzo_3d - version 4.3"
msgstr "Funksjoner lagt til Nimzo_3d - versjon 4.3"
