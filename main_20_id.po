#: main_20.cpp:3
msgid "Dock window"
msgstr "Jendela dok"

#: main_20.cpp:5
msgid "Check to dock the window with the game moves list box"
msgstr "Centang untuk menempelkan jendela dengan kotak daftar gerakan permainan."

#: main_20.cpp:7
msgid "Dock window  :  Check to dock the media player window"
msgstr "Jendela dok: Centang untuk menambatkan jendela pemutar media."

#: main_20.cpp:9
msgid "to the game moves list box."
msgstr "ke kotak daftar gerakan permainan."

#: main_20.cpp:12
msgid "Left margin size"
msgstr "Ukuran margin kiri"

#: main_20.cpp:14
msgid "Enter the left margin size in pixels"
msgstr "Masukkan ukuran margin kiri dalam piksel."

#: main_20.cpp:16
msgid "Button space size"
msgstr "Ukuran spasi tombol"

#: main_20.cpp:18
msgid "Enter the button interval space size in pixels"
msgstr "Masukkan ukuran jarak antar tombol dalam piksel."

#: main_20.cpp:20
msgid "Button space size  -  Enter the size in pixels for the gap between"
msgstr "Ukuran jarak antar tombol - Masukkan ukuran dalam piksel untuk jarak di antara tombol."

#: main_20.cpp:21
msgid "the move info controls and the buttons in the eval profile panel (0 - 120)"
msgstr "Kontrol informasi pergerakan dan tombol-tombol di panel profil evaluasi (0 - 120)"

#: main_20.cpp:23
msgid "Left margin size  :  Enter the size in pixels for the left margin of the graph. (60 - 100)"
msgstr "Ukuran margin kiri: Masukkan ukuran dalam piksel untuk margin kiri grafik. (60 - 100)"

#: main_20.cpp:26
msgid "Nimzo_3d_ml (version 4.3) multi-lingual,"
msgstr "Nimzo_3d_ml (versi 4.3) multibahasa,"

#: main_20.cpp:28
msgid "An adjourn game feature to save and restore games"
msgstr "Fitur menunda permainan untuk menyimpan dan melanjutkan permainan."

#: main_20.cpp:30
msgid "with their clock times (version 4.2)"
msgstr "dengan waktu jam mereka (versi 4.2)"

#: main_20.cpp:32
msgid "An option to dock the media player window (version 4.3)"
msgstr "Opsi untuk menempelkan jendela pemutar media (versi 4.3)"

#: main_20.cpp:34
msgid "Features added to Nimzo_3d - version 4.3"
msgstr "Fitur yang ditambahkan ke Nimzo_3d - versi 4.3"
