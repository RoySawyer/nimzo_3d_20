#: main_20.cpp:3
msgid "Dock window"
msgstr "Вікно для закріплення"

#: main_20.cpp:5
msgid "Check to dock the window with the game moves list box"
msgstr "Поставте позначку, щоб закріпити вікно зі списком ігрових ходів"

#: main_20.cpp:7
msgid "Dock window  :  Check to dock the media player window"
msgstr "Закріпити вікно: Позначте, щоб закріпити вікно медіаплеєра"

#: main_20.cpp:9
msgid "to the game moves list box."
msgstr "до списку ігрових ходів."

#: main_20.cpp:12
msgid "Left margin size"
msgstr "Розмір лівого поля"

#: main_20.cpp:14
msgid "Enter the left margin size in pixels"
msgstr "Введіть розмір лівого поля в пікселях"

#: main_20.cpp:16
msgid "Button space size"
msgstr "Розмір простору для кнопок"

#: main_20.cpp:18
msgid "Enter the button interval space size in pixels"
msgstr "Введіть розмір інтервалу між кнопками в пікселях"

#: main_20.cpp:20
msgid "Button space size  -  Enter the size in pixels for the gap between"
msgstr "Розмір проміжку між кнопками – введіть розмір у пікселях для проміжку між"

#: main_20.cpp:21
msgid "the move info controls and the buttons in the eval profile panel (0 - 120)"
msgstr "елементи керування інформацією про переміщення та кнопки на панелі профілю оцінки (0 - 120)"

#: main_20.cpp:23
msgid "Left margin size  :  Enter the size in pixels for the left margin of the graph. (60 - 100)"
msgstr "Розмір лівого поля: Введіть розмір лівого поля графіка в пікселях. (60 - 100)"

#: main_20.cpp:26
msgid "Nimzo_3d_ml (version 4.3) multi-lingual,"
msgstr "Nimzo_3d_ml (версія 4.3) багатомовна,"

#: main_20.cpp:28
msgid "An adjourn game feature to save and restore games"
msgstr "Функція відкладення гри для збереження та відновлення ігор"

#: main_20.cpp:30
msgid "with their clock times (version 4.2)"
msgstr "з їхнім часом (версія 4.2)"

#: main_20.cpp:32
msgid "An option to dock the media player window (version 4.3)"
msgstr "Опція закріплення вікна медіаплеєра (версія 4.3)"

#: main_20.cpp:34
msgid "Features added to Nimzo_3d - version 4.3"
msgstr "Функції, додані до Nimzo_3d - версія 4.3"
