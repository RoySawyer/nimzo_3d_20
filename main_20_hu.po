#: main_20.cpp:3
msgid "Dock window"
msgstr "Dokkolóablak"

#: main_20.cpp:5
msgid "Check to dock the window with the game moves list box"
msgstr "Jelölje be, ha a játéklépések listáját szeretné dokkolni az ablakban"

#: main_20.cpp:7
msgid "Dock window  :  Check to dock the media player window"
msgstr "Dokkolási ablak: Jelölje be a médialejátszó ablakának dokkolásához"

#: main_20.cpp:9
msgid "to the game moves list box."
msgstr "a játéklépések listájához."

#: main_20.cpp:12
msgid "Left margin size"
msgstr "Bal margó mérete"

#: main_20.cpp:14
msgid "Enter the left margin size in pixels"
msgstr "Adja meg a bal margó méretét képpontban"

#: main_20.cpp:16
msgid "Button space size"
msgstr "Gomb helyének mérete"

#: main_20.cpp:18
msgid "Enter the button interval space size in pixels"
msgstr "Adja meg a gombok közötti távolságot képpontban"

#: main_20.cpp:20
msgid "Button space size  -  Enter the size in pixels for the gap between"
msgstr "Gombok közötti térköz mérete – Adja meg a gombok közötti rés méretét képpontban"

#: main_20.cpp:21
msgid "the move info controls and the buttons in the eval profile panel (0 - 120)"
msgstr "az áthelyezési információk vezérlői és a kiértékelési profil panel gombjai (0 - 120)"

#: main_20.cpp:23
msgid "Left margin size  :  Enter the size in pixels for the left margin of the graph. (60 - 100)"
msgstr "Bal margó mérete: Adja meg a grafikon bal margójának méretét pixelben. (60 - 100)"

#: main_20.cpp:26
msgid "Nimzo_3d_ml (version 4.3) multi-lingual,"
msgstr "Nimzo_3d_ml (4.3-as verzió) többnyelvű,"

#: main_20.cpp:28
msgid "An adjourn game feature to save and restore games"
msgstr "Játékszünet funkció a játékok mentéséhez és visszaállításához"

#: main_20.cpp:30
msgid "with their clock times (version 4.2)"
msgstr "az óráikkal (4.2-es verzió)"

#: main_20.cpp:32
msgid "An option to dock the media player window (version 4.3)"
msgstr "Lehetőség a médialejátszó ablakának dokkolására (4.3-as verzió)"

#: main_20.cpp:34
msgid "Features added to Nimzo_3d - version 4.3"
msgstr "A Nimzo_3d 4.3-as verziójához hozzáadott funkciók"
