#: main_20.cpp:3
msgid "Dock window"
msgstr "پنجره بارانداز"

#: main_20.cpp:5
msgid "Check to dock the window with the game moves list box"
msgstr "برای اتصال پنجره به کادر لیست حرکات بازی، علامت بزنید."

#: main_20.cpp:7
msgid "Dock window  :  Check to dock the media player window"
msgstr "پنجره‌ی داک: برای داک کردن پنجره‌ی پخش‌کننده‌ی رسانه، علامت بزنید"

#: main_20.cpp:9
msgid "to the game moves list box."
msgstr "به کادر لیست حرکات بازی."

#: main_20.cpp:12
msgid "Left margin size"
msgstr "اندازه حاشیه چپ"

#: main_20.cpp:14
msgid "Enter the left margin size in pixels"
msgstr "اندازه حاشیه سمت چپ را بر حسب پیکسل وارد کنید"

#: main_20.cpp:16
msgid "Button space size"
msgstr "اندازه فضای دکمه"

#: main_20.cpp:18
msgid "Enter the button interval space size in pixels"
msgstr "اندازه فاصله بین دکمه‌ها را بر حسب پیکسل وارد کنید"

#: main_20.cpp:20
msgid "Button space size  -  Enter the size in pixels for the gap between"
msgstr "اندازه فضای دکمه - اندازه فاصله بین دکمه‌ها را بر حسب پیکسل وارد کنید."

#: main_20.cpp:21
msgid "the move info controls and the buttons in the eval profile panel (0 - 120)"
msgstr "کنترل‌های اطلاعات حرکت و دکمه‌های موجود در پنل پروفایل ارزیابی (0 - 120)"

#: main_20.cpp:23
msgid "Left margin size  :  Enter the size in pixels for the left margin of the graph. (60 - 100)"
msgstr "اندازه حاشیه چپ: اندازه حاشیه چپ نمودار را بر حسب پیکسل وارد کنید. (60 - 100)"

#: main_20.cpp:26
msgid "Nimzo_3d_ml (version 4.3) multi-lingual,"
msgstr "Nimzo_3d_ml (نسخه ۴.۳) چندزبانه،"

#: main_20.cpp:28
msgid "An adjourn game feature to save and restore games"
msgstr "قابلیت تعویق بازی برای ذخیره و بازیابی بازی‌ها"

#: main_20.cpp:30
msgid "with their clock times (version 4.2)"
msgstr "به همراه زمان ساعت آنها (نسخه ۴.۲)"

#: main_20.cpp:32
msgid "An option to dock the media player window (version 4.3)"
msgstr "گزینه‌ای برای اتصال پنجره پخش‌کننده رسانه (نسخه ۴.۳)"

#: main_20.cpp:34
msgid "Features added to Nimzo_3d - version 4.3"
msgstr "ویژگی‌های اضافه شده به Nimzo_3d - نسخه ۴.۳"
