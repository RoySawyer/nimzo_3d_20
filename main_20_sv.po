#: main_20.cpp:3
msgid "Dock window"
msgstr "Dockningsfönster"

#: main_20.cpp:5
msgid "Check to dock the window with the game moves list box"
msgstr "Markera om du vill docka fönstret med listrutan för spelrörelser"

#: main_20.cpp:7
msgid "Dock window  :  Check to dock the media player window"
msgstr "Docka fönster: Markera för att docka mediaspelarfönstret"

#: main_20.cpp:9
msgid "to the game moves list box."
msgstr "till listrutan för spelrörelser."

#: main_20.cpp:12
msgid "Left margin size"
msgstr "Vänstermarginalstorlek"

#: main_20.cpp:14
msgid "Enter the left margin size in pixels"
msgstr "Ange vänstermarginalens storlek i pixlar"

#: main_20.cpp:16
msgid "Button space size"
msgstr "Knapputrymmesstorlek"

#: main_20.cpp:18
msgid "Enter the button interval space size in pixels"
msgstr "Ange storleken på knappintervallet i pixlar"

#: main_20.cpp:20
msgid "Button space size  -  Enter the size in pixels for the gap between"
msgstr "Knappavståndsstorlek - Ange storleken i pixlar för avståndet mellan"

#: main_20.cpp:21
msgid "the move info controls and the buttons in the eval profile panel (0 - 120)"
msgstr "kontrollerna för rörelseinformation och knapparna i utvärderingsprofilpanelen (0–120)"

#: main_20.cpp:23
msgid "Left margin size  :  Enter the size in pixels for the left margin of the graph. (60 - 100)"
msgstr "Vänstermarginalstorlek: Ange storleken i pixlar för grafens vänstra marginal. (60 - 100)"

#: main_20.cpp:26
msgid "Nimzo_3d_ml (version 4.3) multi-lingual,"
msgstr "Nimzo_3d_ml (version 4.3) flerspråkig,"

#: main_20.cpp:28
msgid "An adjourn game feature to save and restore games"
msgstr "En funktion för att pausa spelet för att spara och återställa spel"

#: main_20.cpp:30
msgid "with their clock times (version 4.2)"
msgstr "med deras klocktider (version 4.2)"

#: main_20.cpp:32
msgid "An option to dock the media player window (version 4.3)"
msgstr "Ett alternativ för att docka mediaspelarfönstret (version 4.3)"

#: main_20.cpp:34
msgid "Features added to Nimzo_3d - version 4.3"
msgstr "Funktioner tillagda i Nimzo_3d - version 4.3"
