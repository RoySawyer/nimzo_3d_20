#: main_20.cpp:3
msgid "Dock window"
msgstr "Ventana de muelle"

#: main_20.cpp:5
msgid "Check to dock the window with the game moves list box"
msgstr "Marque la casilla para acoplar la ventana con el cuadro de lista de movimientos del juego."

#: main_20.cpp:7
msgid "Dock window  :  Check to dock the media player window"
msgstr "Acoplar ventana: Marque esta opción para acoplar la ventana del reproductor multimedia."

#: main_20.cpp:9
msgid "to the game moves list box."
msgstr "a la lista de movimientos del juego."

#: main_20.cpp:12
msgid "Left margin size"
msgstr "Tamaño del margen izquierdo"

#: main_20.cpp:14
msgid "Enter the left margin size in pixels"
msgstr "Introduzca el tamaño del margen izquierdo en píxeles."

#: main_20.cpp:16
msgid "Button space size"
msgstr "Tamaño del espacio del botón"

#: main_20.cpp:18
msgid "Enter the button interval space size in pixels"
msgstr "Introduzca el tamaño del espacio entre botones en píxeles."

#: main_20.cpp:20
msgid "Button space size  -  Enter the size in pixels for the gap between"
msgstr "Tamaño del espacio entre botones: introduzca el tamaño en píxeles para el espacio entre"

#: main_20.cpp:21
msgid "the move info controls and the buttons in the eval profile panel (0 - 120)"
msgstr "los controles de información de movimiento y los botones en el panel de perfil de evaluación (0 - 120)"

#: main_20.cpp:23
msgid "Left margin size  :  Enter the size in pixels for the left margin of the graph. (60 - 100)"
msgstr "Tamaño del margen izquierdo: Introduzca el tamaño en píxeles para el margen izquierdo del gráfico. (60 - 100)"

#: main_20.cpp:26
msgid "Nimzo_3d_ml (version 4.3) multi-lingual,"
msgstr "Nimzo_3d_ml (versión 4.3) multilingüe,"

#: main_20.cpp:28
msgid "An adjourn game feature to save and restore games"
msgstr "Una función para aplazar el juego y guardar y restaurar partidas."

#: main_20.cpp:30
msgid "with their clock times (version 4.2)"
msgstr "con sus horas de reloj (versión 4.2)"

#: main_20.cpp:32
msgid "An option to dock the media player window (version 4.3)"
msgstr "Opción para acoplar la ventana del reproductor multimedia (versión 4.3)"

#: main_20.cpp:34
msgid "Features added to Nimzo_3d - version 4.3"
msgstr "Funcionalidades añadidas a Nimzo_3d - versión 4.3"
