#: main_20.cpp:3
msgid "Dock window"
msgstr "Fereastră de andocare"

#: main_20.cpp:5
msgid "Check to dock the window with the game moves list box"
msgstr "Bifați pentru a andoca fereastra cu caseta listă de mutări din joc"

#: main_20.cpp:7
msgid "Dock window  :  Check to dock the media player window"
msgstr "Fereastră de andocare: Bifați pentru a andoca fereastra playerului media"

#: main_20.cpp:9
msgid "to the game moves list box."
msgstr "la caseta cu lista de mutări din joc."

#: main_20.cpp:12
msgid "Left margin size"
msgstr "Dimensiunea marginii stângi"

#: main_20.cpp:14
msgid "Enter the left margin size in pixels"
msgstr "Introduceți dimensiunea marginii stângi în pixeli"

#: main_20.cpp:16
msgid "Button space size"
msgstr "Dimensiunea spațiului butonului"

#: main_20.cpp:18
msgid "Enter the button interval space size in pixels"
msgstr "Introduceți dimensiunea intervalului butonului în pixeli"

#: main_20.cpp:20
msgid "Button space size  -  Enter the size in pixels for the gap between"
msgstr "Dimensiunea spațiului butonului - Introduceți dimensiunea în pixeli pentru spațiul dintre"

#: main_20.cpp:21
msgid "the move info controls and the buttons in the eval profile panel (0 - 120)"
msgstr "controalele de informații despre mutare și butoanele din panoul profilului de evaluare (0 - 120)"

#: main_20.cpp:23
msgid "Left margin size  :  Enter the size in pixels for the left margin of the graph. (60 - 100)"
msgstr "Dimensiunea marginii stângi: Introduceți dimensiunea în pixeli pentru marginea stângă a graficului. (60 - 100)"

#: main_20.cpp:26
msgid "Nimzo_3d_ml (version 4.3) multi-lingual,"
msgstr "Nimzo_3d_ml (versiunea 4.3) multilingv,"

#: main_20.cpp:28
msgid "An adjourn game feature to save and restore games"
msgstr "O funcție de amânare a jocului pentru a salva și restaura jocurile"

#: main_20.cpp:30
msgid "with their clock times (version 4.2)"
msgstr "cu orele lor de ceas (versiunea 4.2)"

#: main_20.cpp:32
msgid "An option to dock the media player window (version 4.3)"
msgstr "O opțiune pentru a andoca fereastra playerului media (versiunea 4.3)"

#: main_20.cpp:34
msgid "Features added to Nimzo_3d - version 4.3"
msgstr "Funcții adăugate la Nimzo_3d - versiunea 4.3"
