#: main_20.cpp:3
msgid "Dock window"
msgstr "חלון עגינה"

#: main_20.cpp:5
msgid "Check to dock the window with the game moves list box"
msgstr "סמן כדי לעגן את החלון עם תיבת הרשימה של מהלכי המשחק"

#: main_20.cpp:7
msgid "Dock window  :  Check to dock the media player window"
msgstr "עגינה של חלון: סמן כדי לעגן את חלון נגן המדיה"

#: main_20.cpp:9
msgid "to the game moves list box."
msgstr "לתיבת רשימת המהלכים של המשחק."

#: main_20.cpp:12
msgid "Left margin size"
msgstr "גודל השוליים השמאליים"

#: main_20.cpp:14
msgid "Enter the left margin size in pixels"
msgstr "הזן את גודל השוליים השמאליים בפיקסלים"

#: main_20.cpp:16
msgid "Button space size"
msgstr "גודל שטח הכפתורים"

#: main_20.cpp:18
msgid "Enter the button interval space size in pixels"
msgstr "הזן את גודל מרווח הלחצנים בפיקסלים"

#: main_20.cpp:20
msgid "Button space size  -  Enter the size in pixels for the gap between"
msgstr "גודל מרווח כפתורים - הזן את הגודל בפיקסלים עבור המרווח בין"

#: main_20.cpp:21
msgid "the move info controls and the buttons in the eval profile panel (0 - 120)"
msgstr "פקדי מידע המהלך והכפתורים בחלונית פרופיל ההערכה (0 - 120)"

#: main_20.cpp:23
msgid "Left margin size  :  Enter the size in pixels for the left margin of the graph. (60 - 100)"
msgstr "גודל שוליים שמאליים: הזן את הגודל בפיקסלים עבור השוליים השמאליים של הגרף. (60 - 100)"

#: main_20.cpp:26
msgid "Nimzo_3d_ml (version 4.3) multi-lingual,"
msgstr "Nimzo_3d_ml (גרסה 4.3) רב לשוני,"

#: main_20.cpp:28
msgid "An adjourn game feature to save and restore games"
msgstr "תכונת דחיית משחק לשמירה ושחזור משחקים"

#: main_20.cpp:30
msgid "with their clock times (version 4.2)"
msgstr "עם זמני השעון שלהם (גרסה 4.2)"

#: main_20.cpp:32
msgid "An option to dock the media player window (version 4.3)"
msgstr "אפשרות לעגן את חלון נגן המדיה (גרסה 4.3)"

#: main_20.cpp:34
msgid "Features added to Nimzo_3d - version 4.3"
msgstr "תכונות שנוספו ל-Nimzo_3d - גרסה 4.3"
