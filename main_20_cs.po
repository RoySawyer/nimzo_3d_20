#: main_20.cpp:3
msgid "Dock window"
msgstr "Ukotvit okno"

#: main_20.cpp:5
msgid "Check to dock the window with the game moves list box"
msgstr "Zaškrtněte pro ukotvení okna se seznamem herních tahů."

#: main_20.cpp:7
msgid "Dock window  :  Check to dock the media player window"
msgstr "Ukotvit okno: Zaškrtněte pro ukotvení okna přehrávače médií"

#: main_20.cpp:9
msgid "to the game moves list box."
msgstr "do seznamu herních tahů."

#: main_20.cpp:12
msgid "Left margin size"
msgstr "Velikost levého okraje"

#: main_20.cpp:14
msgid "Enter the left margin size in pixels"
msgstr "Zadejte velikost levého okraje v pixelech"

#: main_20.cpp:16
msgid "Button space size"
msgstr "Velikost prostoru pro tlačítko"

#: main_20.cpp:18
msgid "Enter the button interval space size in pixels"
msgstr "Zadejte velikost mezery mezi tlačítky v pixelech"

#: main_20.cpp:20
msgid "Button space size  -  Enter the size in pixels for the gap between"
msgstr "Velikost prostoru pro tlačítko – Zadejte velikost mezery mezi tlačítky v pixelech"

#: main_20.cpp:21
msgid "the move info controls and the buttons in the eval profile panel (0 - 120)"
msgstr "ovládací prvky informací o pohybu a tlačítka v panelu profilu eval (0–120)"

#: main_20.cpp:23
msgid "Left margin size  :  Enter the size in pixels for the left margin of the graph. (60 - 100)"
msgstr "Velikost levého okraje: Zadejte velikost levého okraje grafu v pixelech. (60–100)"

#: main_20.cpp:26
msgid "Nimzo_3d_ml (version 4.3) multi-lingual,"
msgstr "Nimzo_3d_ml (verze 4.3) vícejazyčný,"

#: main_20.cpp:28
msgid "An adjourn game feature to save and restore games"
msgstr "Funkce odložení hry pro ukládání a obnovení her"

#: main_20.cpp:30
msgid "with their clock times (version 4.2)"
msgstr "s jejich časy (verze 4.2)"

#: main_20.cpp:32
msgid "An option to dock the media player window (version 4.3)"
msgstr "Možnost ukotvení okna přehrávače médií (verze 4.3)"

#: main_20.cpp:34
msgid "Features added to Nimzo_3d - version 4.3"
msgstr "Nové funkce do Nimzo_3d - verze 4.3"
