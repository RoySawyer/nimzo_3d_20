#: main_20.cpp:3
msgid "Dock window"
msgstr "Dirisha la gati"

#: main_20.cpp:5
msgid "Check to dock the window with the game moves list box"
msgstr "Angalia ili kufunga dirisha na kisanduku cha orodha ya hatua za mchezo"

#: main_20.cpp:7
msgid "Dock window  :  Check to dock the media player window"
msgstr "Dirisha la gati: Angalia ili kuambatisha dirisha la kicheza media"

#: main_20.cpp:9
msgid "to the game moves list box."
msgstr "kwenye kisanduku cha orodha ya hatua za mchezo."

#: main_20.cpp:12
msgid "Left margin size"
msgstr "Ukubwa wa pambizo la kushoto"

#: main_20.cpp:14
msgid "Enter the left margin size in pixels"
msgstr "Ingiza ukubwa wa pembezoni ya kushoto katika pikseli"

#: main_20.cpp:16
msgid "Button space size"
msgstr "Ukubwa wa nafasi ya vifungo"

#: main_20.cpp:18
msgid "Enter the button interval space size in pixels"
msgstr "Ingiza ukubwa wa nafasi ya muda wa kitufe katika pikseli"

#: main_20.cpp:20
msgid "Button space size  -  Enter the size in pixels for the gap between"
msgstr "Ukubwa wa nafasi ya vitufe - Ingiza ukubwa katika pikseli kwa pengo kati ya"

#: main_20.cpp:21
msgid "the move info controls and the buttons in the eval profile panel (0 - 120)"
msgstr "vidhibiti vya taarifa za kuhamisha na vitufe kwenye paneli ya wasifu wa eval (0 - 120)"

#: main_20.cpp:23
msgid "Left margin size  :  Enter the size in pixels for the left margin of the graph. (60 - 100)"
msgstr "Ukubwa wa pambizo la kushoto: Ingiza ukubwa katika pikseli kwa pambizo la kushoto la grafu. (60 - 100)"

#: main_20.cpp:26
msgid "Nimzo_3d_ml (version 4.3) multi-lingual,"
msgstr "Nimzo_3d_ml (toleo la 4.3) la lugha nyingi,"

#: main_20.cpp:28
msgid "An adjourn game feature to save and restore games"
msgstr "Kipengele cha kuahirisha mchezo ili kuhifadhi na kurejesha michezo"

#: main_20.cpp:30
msgid "with their clock times (version 4.2)"
msgstr "na saa zao (toleo la 4.2)"

#: main_20.cpp:32
msgid "An option to dock the media player window (version 4.3)"
msgstr "Chaguo la kuweka kizimbani dirisha la kichezaji cha media (toleo la 4.3)"

#: main_20.cpp:34
msgid "Features added to Nimzo_3d - version 4.3"
msgstr "Vipengele vimeongezwa kwenye Nimzo_3d - toleo la 4.3"
