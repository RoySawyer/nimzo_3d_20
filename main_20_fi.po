#: main_20.cpp:3
msgid "Dock window"
msgstr "Telakointi-ikkuna"

#: main_20.cpp:5
msgid "Check to dock the window with the game moves list box"
msgstr "Valitse tämä, jos haluat ikkunan kiinnittyvän peliliikkeiden luetteloon"

#: main_20.cpp:7
msgid "Dock window  :  Check to dock the media player window"
msgstr "Telakointi-ikkuna: Valitse tämä, jos haluat telakoida mediasoittimen ikkunan."

#: main_20.cpp:9
msgid "to the game moves list box."
msgstr "pelin siirtojen luetteloruutuun."

#: main_20.cpp:12
msgid "Left margin size"
msgstr "Vasemman marginaalin koko"

#: main_20.cpp:14
msgid "Enter the left margin size in pixels"
msgstr "Anna vasemman marginaalin koko pikseleinä"

#: main_20.cpp:16
msgid "Button space size"
msgstr "Painikkeen tilan koko"

#: main_20.cpp:18
msgid "Enter the button interval space size in pixels"
msgstr "Anna painikkeiden välisen tilan koko pikseleinä"

#: main_20.cpp:20
msgid "Button space size  -  Enter the size in pixels for the gap between"
msgstr "Painikkeen välin koko - Anna painikkeiden välisen tilan koko pikseleinä"

#: main_20.cpp:21
msgid "the move info controls and the buttons in the eval profile panel (0 - 120)"
msgstr "siirtotietojen säätimet ja eval-profiilipaneelin painikkeet (0–120)"

#: main_20.cpp:23
msgid "Left margin size  :  Enter the size in pixels for the left margin of the graph. (60 - 100)"
msgstr "Vasemman reunuksen koko: Anna kaavion vasemman reunuksen koko pikseleinä. (60–100)"

#: main_20.cpp:26
msgid "Nimzo_3d_ml (version 4.3) multi-lingual,"
msgstr "Nimzo_3d_ml (versio 4.3) monikielinen,"

#: main_20.cpp:28
msgid "An adjourn game feature to save and restore games"
msgstr "Pelin keskeytystoiminto pelien tallentamiseen ja palauttamiseen"

#: main_20.cpp:30
msgid "with their clock times (version 4.2)"
msgstr "kellonaikoineen (versio 4.2)"

#: main_20.cpp:32
msgid "An option to dock the media player window (version 4.3)"
msgstr "Mediasoittimen ikkunan telakointimahdollisuus (versio 4.3)"

#: main_20.cpp:34
msgid "Features added to Nimzo_3d - version 4.3"
msgstr "Nimzo_3d:hen lisätyt ominaisuudet - versio 4.3"
