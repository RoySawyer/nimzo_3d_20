#: main_20.cpp:3
msgid "Dock window"
msgstr "Okno dokujące"

#: main_20.cpp:5
msgid "Check to dock the window with the game moves list box"
msgstr "Zaznacz, aby zadokować okno z listą ruchów gry"

#: main_20.cpp:7
msgid "Dock window  :  Check to dock the media player window"
msgstr "Dokuj okno: Zaznacz, aby zadokować okno odtwarzacza multimedialnego"

#: main_20.cpp:9
msgid "to the game moves list box."
msgstr "do listy ruchów gry."

#: main_20.cpp:12
msgid "Left margin size"
msgstr "Rozmiar lewego marginesu"

#: main_20.cpp:14
msgid "Enter the left margin size in pixels"
msgstr "Wprowadź rozmiar lewego marginesu w pikselach"

#: main_20.cpp:16
msgid "Button space size"
msgstr "Rozmiar przestrzeni przycisku"

#: main_20.cpp:18
msgid "Enter the button interval space size in pixels"
msgstr "Wprowadź rozmiar odstępu między przyciskami w pikselach"

#: main_20.cpp:20
msgid "Button space size  -  Enter the size in pixels for the gap between"
msgstr "Rozmiar odstępu między przyciskami – wprowadź rozmiar odstępu w pikselach"

#: main_20.cpp:21
msgid "the move info controls and the buttons in the eval profile panel (0 - 120)"
msgstr "elementy sterujące informacjami o ruchu i przyciski w panelu profilu oceny (0–120)"

#: main_20.cpp:23
msgid "Left margin size  :  Enter the size in pixels for the left margin of the graph. (60 - 100)"
msgstr "Rozmiar lewego marginesu: Wprowadź rozmiar lewego marginesu wykresu w pikselach. (60 - 100)"

#: main_20.cpp:26
msgid "Nimzo_3d_ml (version 4.3) multi-lingual,"
msgstr "Nimzo_3d_ml (wersja 4.3) wielojęzyczna,"

#: main_20.cpp:28
msgid "An adjourn game feature to save and restore games"
msgstr "Funkcja odroczenia gry umożliwiająca zapisywanie i przywracanie gier"

#: main_20.cpp:30
msgid "with their clock times (version 4.2)"
msgstr "z ich czasem zegarowym (wersja 4.2)"

#: main_20.cpp:32
msgid "An option to dock the media player window (version 4.3)"
msgstr "Opcja dokowania okna odtwarzacza multimedialnego (wersja 4.3)"

#: main_20.cpp:34
msgid "Features added to Nimzo_3d - version 4.3"
msgstr "Funkcje dodane do Nimzo_3d – wersja 4.3"
