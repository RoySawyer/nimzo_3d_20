#: main_20.cpp:3
msgid "Dock window"
msgstr "Tagar tashar jiragen ruwa"

#: main_20.cpp:5
msgid "Check to dock the window with the game moves list box"
msgstr "Duba don haɗa taga tare da akwatin jerin abubuwan motsa wasan"

#: main_20.cpp:7
msgid "Dock window  :  Check to dock the media player window"
msgstr "Tagar Dock: Duba don haɗa tagar mai kunna kafofin watsa labarai"

#: main_20.cpp:9
msgid "to the game moves list box."
msgstr "zuwa akwatin jerin abubuwan da ke motsa wasan."

#: main_20.cpp:12
msgid "Left margin size"
msgstr "Girman gefen hagu"

#: main_20.cpp:14
msgid "Enter the left margin size in pixels"
msgstr "Shigar da girman gefen hagu a cikin pixels"

#: main_20.cpp:16
msgid "Button space size"
msgstr "Girman sararin maɓalli"

#: main_20.cpp:18
msgid "Enter the button interval space size in pixels"
msgstr "Shigar da girman sararin tazara a cikin pixels na maɓalli"

#: main_20.cpp:20
msgid "Button space size  -  Enter the size in pixels for the gap between"
msgstr "Girman sarari na maɓalli - Shigar da girman a cikin pixels don tazara tsakanin"

#: main_20.cpp:21
msgid "the move info controls and the buttons in the eval profile panel (0 - 120)"
msgstr "Sarrafa bayanan motsi da maɓallan da ke cikin kwamitin bayanin martaba na kimantawa (0 - 120)"

#: main_20.cpp:23
msgid "Left margin size  :  Enter the size in pixels for the left margin of the graph. (60 - 100)"
msgstr "Girman gefen hagu: Shigar da girman a cikin pixels don gefen hagu na jadawali. (60 - 100)"

#: main_20.cpp:26
msgid "Nimzo_3d_ml (version 4.3) multi-lingual,"
msgstr "Nimzo_3d_ml (sigar 4.3) mai harsuna da yawa,"

#: main_20.cpp:28
msgid "An adjourn game feature to save and restore games"
msgstr "Fasalin wasan dakatarwa don adanawa da dawo da wasanni"

#: main_20.cpp:30
msgid "with their clock times (version 4.2)"
msgstr "tare da lokutan agogon su (sigar 4.2)"

#: main_20.cpp:32
msgid "An option to dock the media player window (version 4.3)"
msgstr "Zaɓin da za a iya amfani da shi don haɗa tagar mai kunna kafofin watsa labarai (sigar 4.3)"

#: main_20.cpp:34
msgid "Features added to Nimzo_3d - version 4.3"
msgstr "An ƙara fasaloli zuwa Nimzo_3d - sigar 4.3"
