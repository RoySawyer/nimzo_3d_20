#: main_20.cpp:3
msgid "Dock window"
msgstr "نافذة الرصيف"

#: main_20.cpp:5
msgid "Check to dock the window with the game moves list box"
msgstr "حدد خيار تثبيت النافذة التي تحتوي على مربع قائمة حركات اللعبة"

#: main_20.cpp:7
msgid "Dock window  :  Check to dock the media player window"
msgstr "نافذة الإرساء: حدد هذا الخيار لإرساء نافذة مشغل الوسائط"

#: main_20.cpp:9
msgid "to the game moves list box."
msgstr "إلى مربع قائمة حركات اللعبة."

#: main_20.cpp:12
msgid "Left margin size"
msgstr "حجم الهامش الأيسر"

#: main_20.cpp:14
msgid "Enter the left margin size in pixels"
msgstr "أدخل حجم الهامش الأيسر بالبكسل"

#: main_20.cpp:16
msgid "Button space size"
msgstr "حجم المسافة بين الأزرار"

#: main_20.cpp:18
msgid "Enter the button interval space size in pixels"
msgstr "أدخل حجم المسافة الفاصلة بين الأزرار بالبكسل"

#: main_20.cpp:20
msgid "Button space size  -  Enter the size in pixels for the gap between"
msgstr "حجم مساحة الزر - أدخل حجم المسافة بالبكسل بين"

#: main_20.cpp:21
msgid "the move info controls and the buttons in the eval profile panel (0 - 120)"
msgstr "عناصر التحكم في معلومات الحركة والأزرار الموجودة في لوحة ملف تعريف التقييم (0 - 120)"

#: main_20.cpp:23
msgid "Left margin size  :  Enter the size in pixels for the left margin of the graph. (60 - 100)"
msgstr "حجم الهامش الأيسر: أدخل حجم الهامش الأيسر للرسم البياني بالبكسل. (60 - 100)"

#: main_20.cpp:26
msgid "Nimzo_3d_ml (version 4.3) multi-lingual,"
msgstr "Nimzo_3d_ml (الإصدار 4.3) متعدد اللغات،"

#: main_20.cpp:28
msgid "An adjourn game feature to save and restore games"
msgstr "ميزة تأجيل اللعبة لحفظ واستعادة الألعاب"

#: main_20.cpp:30
msgid "with their clock times (version 4.2)"
msgstr "مع أوقات الساعة الخاصة بهم (الإصدار 4.2)"

#: main_20.cpp:32
msgid "An option to dock the media player window (version 4.3)"
msgstr "خيار لتثبيت نافذة مشغل الوسائط (الإصدار 4.3)"

#: main_20.cpp:34
msgid "Features added to Nimzo_3d - version 4.3"
msgstr "ميزات جديدة تمت إضافتها إلى Nimzo_3d - الإصدار 4.3"
