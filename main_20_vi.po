#: main_20.cpp:3
msgid "Dock window"
msgstr "Cửa sổ bến tàu"

#: main_20.cpp:5
msgid "Check to dock the window with the game moves list box"
msgstr "Chọn tùy chọn neo cửa sổ chứa danh sách các nước đi trong trò chơi."

#: main_20.cpp:7
msgid "Dock window  :  Check to dock the media player window"
msgstr "Cửa sổ neo: Chọn tùy chọn neo cửa sổ trình phát đa phương tiện."

#: main_20.cpp:9
msgid "to the game moves list box."
msgstr "vào hộp danh sách các nước đi trong trò chơi."

#: main_20.cpp:12
msgid "Left margin size"
msgstr "Kích thước lề trái"

#: main_20.cpp:14
msgid "Enter the left margin size in pixels"
msgstr "Nhập kích thước lề trái tính bằng pixel."

#: main_20.cpp:16
msgid "Button space size"
msgstr "kích thước khoảng cách nút"

#: main_20.cpp:18
msgid "Enter the button interval space size in pixels"
msgstr "Nhập kích thước khoảng cách giữa các nút tính bằng pixel."

#: main_20.cpp:20
msgid "Button space size  -  Enter the size in pixels for the gap between"
msgstr "Kích thước khoảng cách nút - Nhập kích thước (tính bằng pixel) cho khoảng cách giữa các nút."

#: main_20.cpp:21
msgid "the move info controls and the buttons in the eval profile panel (0 - 120)"
msgstr "các điều khiển thông tin di chuyển và các nút trong bảng hồ sơ đánh giá (0 - 120)"

#: main_20.cpp:23
msgid "Left margin size  :  Enter the size in pixels for the left margin of the graph. (60 - 100)"
msgstr "Kích thước lề trái: Nhập kích thước tính bằng pixel cho lề trái của biểu đồ. (60 - 100)"

#: main_20.cpp:26
msgid "Nimzo_3d_ml (version 4.3) multi-lingual,"
msgstr "Nimzo_3d_ml (phiên bản 4.3) đa ngôn ngữ,"

#: main_20.cpp:28
msgid "An adjourn game feature to save and restore games"
msgstr "Tính năng tạm dừng trò chơi để lưu và khôi phục trò chơi"

#: main_20.cpp:30
msgid "with their clock times (version 4.2)"
msgstr "với thời gian trên đồng hồ của chúng (phiên bản 4.2)"

#: main_20.cpp:32
msgid "An option to dock the media player window (version 4.3)"
msgstr "Tùy chọn neo cửa sổ trình phát đa phương tiện (phiên bản 4.3)"

#: main_20.cpp:34
msgid "Features added to Nimzo_3d - version 4.3"
msgstr "Các tính năng được thêm vào Nimzo_3d - phiên bản 4.3"
