#: main_20.cpp:3
msgid "Dock window"
msgstr "Dritarja e ankorimit"

#: main_20.cpp:5
msgid "Check to dock the window with the game moves list box"
msgstr "Kontrolloni për të lidhur dritaren me kutinë e listës së lëvizjeve të lojës"

#: main_20.cpp:7
msgid "Dock window  :  Check to dock the media player window"
msgstr "Lidh dritaren: Zgjidh për të lidhur dritaren e luajtësit të medias"

#: main_20.cpp:9
msgid "to the game moves list box."
msgstr "në kutinë e listës së lëvizjeve të lojës."

#: main_20.cpp:12
msgid "Left margin size"
msgstr "Madhësia e marzhit të majtë"

#: main_20.cpp:14
msgid "Enter the left margin size in pixels"
msgstr "Fut madhësinë e margjinës së majtë në piksel"

#: main_20.cpp:16
msgid "Button space size"
msgstr "Madhësia e hapësirës së butonit"

#: main_20.cpp:18
msgid "Enter the button interval space size in pixels"
msgstr "Fut madhësinë e hapësirës së intervalit të butonit në piksel"

#: main_20.cpp:20
msgid "Button space size  -  Enter the size in pixels for the gap between"
msgstr "Madhësia e hapësirës së butonit - Futni madhësinë në piksel për boshllëkun midis"

#: main_20.cpp:21
msgid "the move info controls and the buttons in the eval profile panel (0 - 120)"
msgstr "kontrollet e informacionit të lëvizjes dhe butonat në panelin e profilit të vlerësimit (0 - 120)"

#: main_20.cpp:23
msgid "Left margin size  :  Enter the size in pixels for the left margin of the graph. (60 - 100)"
msgstr "Madhësia e marzhit të majtë: Futni madhësinë në piksel për marzhin e majtë të grafikut. (60 - 100)"

#: main_20.cpp:26
msgid "Nimzo_3d_ml (version 4.3) multi-lingual,"
msgstr "Nimzo_3d_ml (versioni 4.3) shumëgjuhësh,"

#: main_20.cpp:28
msgid "An adjourn game feature to save and restore games"
msgstr "Një veçori shtyrjeje e lojës për të ruajtur dhe rivendosur lojërat"

#: main_20.cpp:30
msgid "with their clock times (version 4.2)"
msgstr "me kohët e tyre të orës (versioni 4.2)"

#: main_20.cpp:32
msgid "An option to dock the media player window (version 4.3)"
msgstr "Një opsion për të lidhur dritaren e media player-it (versioni 4.3)"

#: main_20.cpp:34
msgid "Features added to Nimzo_3d - version 4.3"
msgstr "Karakteristika të shtuara në Nimzo_3d - versioni 4.3"
