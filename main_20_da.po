#: main_20.cpp:3
msgid "Dock window"
msgstr "Dock-vindue"

#: main_20.cpp:5
msgid "Check to dock the window with the game moves list box"
msgstr "Markér for at forankre vinduet med listen over spilbevægelser"

#: main_20.cpp:7
msgid "Dock window  :  Check to dock the media player window"
msgstr "Dock vindue: Markér for at docke medieafspillervinduet"

#: main_20.cpp:9
msgid "to the game moves list box."
msgstr "til listen over spilbevægelser."

#: main_20.cpp:12
msgid "Left margin size"
msgstr "Størrelse på venstre margen"

#: main_20.cpp:14
msgid "Enter the left margin size in pixels"
msgstr "Indtast størrelsen på venstre margen i pixels"

#: main_20.cpp:16
msgid "Button space size"
msgstr "Størrelse på knappladsen"

#: main_20.cpp:18
msgid "Enter the button interval space size in pixels"
msgstr "Indtast størrelsen på knappens interval i pixels"

#: main_20.cpp:20
msgid "Button space size  -  Enter the size in pixels for the gap between"
msgstr "Størrelse på knapafstand - Indtast størrelsen i pixels for mellemrummet mellem"

#: main_20.cpp:21
msgid "the move info controls and the buttons in the eval profile panel (0 - 120)"
msgstr "Bevægelsesinfo-kontrollerne og knapperne i evalueringsprofilpanelet (0 - 120)"

#: main_20.cpp:23
msgid "Left margin size  :  Enter the size in pixels for the left margin of the graph. (60 - 100)"
msgstr "Venstre margenstørrelse: Indtast størrelsen i pixels for grafens venstre margen. (60 - 100)"

#: main_20.cpp:26
msgid "Nimzo_3d_ml (version 4.3) multi-lingual,"
msgstr "Nimzo_3d_ml (version 4.3) flersproget,"

