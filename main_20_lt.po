#: main_20.cpp:3
msgid "Dock window"
msgstr "Doko langas"

#: main_20.cpp:5
msgid "Check to dock the window with the game moves list box"
msgstr "Pažymėkite, jei norite prijungti langą prie žaidimo ėjimų sąrašo"

#: main_20.cpp:7
msgid "Dock window  :  Check to dock the media player window"
msgstr "Prijungti langą: pažymėkite, jei norite prijungti medijos leistuvo langą"

#: main_20.cpp:9
msgid "to the game moves list box."
msgstr "į žaidimo ėjimų sąrašo laukelį."

#: main_20.cpp:12
msgid "Left margin size"
msgstr "Kairiosios paraštės dydis"

#: main_20.cpp:14
msgid "Enter the left margin size in pixels"
msgstr "Įveskite kairiosios paraštės dydį pikseliais"

#: main_20.cpp:16
msgid "Button space size"
msgstr "Mygtuko vietos dydis"

#: main_20.cpp:18
msgid "Enter the button interval space size in pixels"
msgstr "Įveskite mygtuko intervalo dydį pikseliais"

#: main_20.cpp:20
msgid "Button space size  -  Enter the size in pixels for the gap between"
msgstr "Mygtuko tarpo dydis – įveskite tarpo tarp mygtukų dydį pikseliais"

#: main_20.cpp:21
msgid "the move info controls and the buttons in the eval profile panel (0 - 120)"
msgstr "Judėjimo informacijos valdikliai ir mygtukai vertinimo profilio skydelyje (0–120)"

#: main_20.cpp:23
msgid "Left margin size  :  Enter the size in pixels for the left margin of the graph. (60 - 100)"
msgstr "Kairiosios paraštės dydis: įveskite grafiko kairiosios paraštės dydį pikseliais. (60–100)"

#: main_20.cpp:26
msgid "Nimzo_3d_ml (version 4.3) multi-lingual,"
msgstr "„Nimzo_3d_ml“ (4.3 versija) – daugiakalbis,"

#: main_20.cpp:28
msgid "An adjourn game feature to save and restore games"
msgstr "Žaidimo atidėjimo funkcija, skirta išsaugoti ir atkurti žaidimus"

#: main_20.cpp:30
msgid "with their clock times (version 4.2)"
msgstr "su jų laikrodžio laikais (4.2 versija)"

#: main_20.cpp:32
msgid "An option to dock the media player window (version 4.3)"
msgstr "Galimybė prijungti medijos leistuvo langą (4.3 versija)"

#: main_20.cpp:34
msgid "Features added to Nimzo_3d - version 4.3"
msgstr "Į „Nimzo_3d“ – 4.3 versija – pridėtos funkcijos"
